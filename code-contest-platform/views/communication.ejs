<!DOCTYPE html>
<html lang="ka">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Communication — Zarzma Judge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>

  <nav class="zj-navbar">
    <a href="/contests" class="zj-logo">
      <span class="zj-logo-dot"></span>
      Zarzma Judge
    </a>
    <div class="zj-nav-right">
      <% if (typeof contestId !== 'undefined' && contestId) { %>
        <a href="/contest/<%= contestId %>" class="btn-zj btn-zj-ghost btn-zj-sm">← კონტესტი</a>
      <% } else { %>
        <a href="/contests" class="btn-zj btn-zj-ghost btn-zj-sm">← კონტესტები</a>
      <% } %>
    </div>
  </nav>

  <div style="max-width: 820px; margin: 0 auto; padding: 32px 24px;">

    <div class="flex-between mb-4">
      <div>
        <h2 style="font-size: 20px; margin-bottom: 4px;">Communication</h2>
        <% if (typeof contestTitle !== 'undefined' && contestTitle) { %>
          <span style="font-size: 12px; color: var(--text-muted);">კონტესტი: <%= contestTitle %></span>
        <% } %>
      </div>
    </div>

    <!-- ── Ask form (students only) ── -->
    <% if (role !== 'admin' && role !== 'owner') { %>
    <div class="card-zj mb-4">
      <div class="card-header-zj">
        <span style="font-size: 12px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: var(--text-muted);">
          ახალი კითხვა
        </span>
      </div>
      <form action="/communication/ask" method="POST" class="form-zj">
        <input type="hidden" name="contestId" value="<%= contestId %>">
        <div class="form-group">
          <label>ამოცანა / თემა</label>
          <select name="taskName" required>
            <option value="General">ზოგადი კითხვა კონტესტზე</option>
            <% if (typeof tasks !== 'undefined' && tasks) { %>
              <% tasks.forEach(t => { %>
                <option value="<%= t %>"><%= t %></option>
              <% }) %>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label>შეტყობინება</label>
          <textarea name="question" rows="3" placeholder="დაწერე შენი კითხვა..." required
                    style="resize: vertical;"></textarea>
        </div>
        <button type="submit" class="btn-zj btn-zj-primary">გაგზავნა</button>
      </form>
    </div>
    <% } %>

    <!-- ── Messages ── -->
    <p class="section-label mb-3">კითხვები და პასუხები</p>

    <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
      <% messages.forEach(msg => { %>
      <div class="msg-zj">
        <!-- header -->
        <div class="flex-between mb-2">
          <div class="flex flex-center gap-2">
            <span class="badge-zj badge-muted mono"><%= msg.taskName %></span>
            <span style="font-size: 13px; font-weight: 600;"><%= msg.userEmail %></span>
            <% if (msg.contestTitle) { %>
              <span style="font-size: 11px; color: var(--accent);">(<%= msg.contestTitle %>)</span>
            <% } %>
          </div>
          <span style="font-size: 11px; color: var(--text-muted); font-family: var(--font-mono);"><%= msg.time %></span>
        </div>

        <!-- question body -->
        <p style="font-size: 14px; color: var(--text-primary); white-space: pre-line; margin: 0 0 10px;">
          <%= msg.question %>
        </p>

        <!-- answer / reply -->
        <% if (msg.answer) { %>
          <div class="msg-reply">
            <div style="font-size: 11px; font-weight: 700; color: var(--accent); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.4px;">
              პასუხი ადმინისგან
            </div>
            <p style="font-size: 13px; color: var(--text-primary); white-space: pre-line; margin: 0;"><%= msg.answer %></p>
          </div>
        <% } else { %>
          <% if (role === 'admin' || role === 'owner') { %>
            <form action="/communication/reply" method="POST" class="form-zj">
              <input type="hidden" name="messageId" value="<%= msg.id %>">
              <input type="hidden" name="redirectUrl" value="/communication?contestId=<%= contestId || '' %>">
              <div style="display: flex; gap: 8px;">
                <input type="text" name="answer" placeholder="პასუხი..." required style="flex: 1;">
                <button type="submit" class="btn-zj btn-zj-success" style="white-space: nowrap;">გაგზავნა</button>
              </div>
            </form>
          <% } else { %>
            <span style="font-size: 12px; color: var(--text-muted);">⏳ მოლოდინის რეჟიმში...</span>
          <% } %>
        <% } %>
      </div>
      <% }) %>
    <% } else { %>
      <div class="card-zj" style="text-align: center; padding: 48px 24px;">
        <p style="color: var(--text-muted);">კითხვების ისტორია ცარიელია.</p>
      </div>
    <% } %>

  </div>
</body>
</html>
