<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <title>Create Contest</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light" style="padding-top: 60px; font-family: system-ui, sans-serif;">
    <div class="container d-flex justify-content-center">
        <div class="card card-body shadow-sm p-4 w-100" style="max-width: 500px;">
            <h4 class="mb-4 fw-bold">Create New Contest</h4>
            <form action="/admin/create-contest" method="POST">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-secondary">CONTEST TITLE</label>
                    <input type="text" name="title" class="form-control form-control-sm" required autocomplete="off">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-secondary">TASKS (მძიმეებით გამოყოფილი)</label>
                    <input type="text" name="tasks" class="form-control form-control-sm" placeholder="power, leprikon" autocomplete="off">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-secondary">DURATION (ხანგრძლივობა წუთებში)</label>
                    <input type="number" name="duration" class="form-control form-control-sm" value="180" required>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <a href="/contests" class="btn btn-light border btn-sm">Cancel</a>
                    <button type="submit" class="btn btn-success btn-sm px-3 fw-bold">Save Contest</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>