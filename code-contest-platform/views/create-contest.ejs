<!DOCTYPE html>
<html lang="ka">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>კონტესტის შექმნა — Zarzma Judge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>

  <nav class="zj-navbar">
    <a href="/contests" class="zj-logo">
      <span class="zj-logo-dot"></span>
      Zarzma Judge
    </a>
    <a href="/contests" class="btn-zj btn-zj-ghost btn-zj-sm">← უკან</a>
  </nav>

  <div style="max-width: 720px; margin: 0 auto; padding: 32px 24px;">

    <div class="mb-4">
      <h2 style="font-size: 20px; margin-bottom: 4px;">ახალი კონტესტის შექმნა</h2>
      <p style="color: var(--text-muted); font-size: 13px;">შეავსე ველები და დაამატე ამოცანები PDF-ებით და სატესტო ფაილებით.</p>
    </div>

    <form action="/admin/create-contest" method="POST" enctype="multipart/form-data" class="form-zj">

      <div class="card-zj mb-3">
        <div class="form-group">
          <label>კონტესტის დასახელება</label>
          <input type="text" name="title" required placeholder="მაგ: შიდა შესარჩევი ტური #1">
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label>ხანგრძლივობა (წუთი)</label>
          <input type="number" name="duration" value="180" required min="1" style="max-width: 200px;">
        </div>
      </div>

      <p class="section-label mb-2">ამოცანები</p>
      <div id="tasksContainer"></div>

      <button type="button" onclick="addTask()"
              class="btn-zj btn-zj-ghost mb-4" style="width: 100%; justify-content: center; border-style: dashed;">
        + ამოცანის დამატება
      </button>

      <hr class="divider">

      <div class="flex flex-center gap-2">
        <button type="submit" class="btn-zj btn-zj-primary">კონტესტის შექმნა</button>
        <a href="/contests" class="btn-zj btn-zj-ghost">გაუქმება</a>
      </div>
    </form>
  </div>

  <script>
    let count = 0;

    function addTask() {
      count++;
      const c = document.getElementById('tasksContainer');
      const div = document.createElement('div');
      div.className = 'task-block-zj';
      div.id = 'task_' + count;
      div.innerHTML = `
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
          <span style="font-family: var(--font-mono); font-size: 12px; font-weight: 700; color: var(--accent);">
            TASK #${count}
          </span>
          <button type="button" onclick="removeTask(${count})"
                  class="btn-zj btn-zj-danger btn-zj-sm">წაშლა</button>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 140px 140px; gap: 10px; margin-bottom: 12px;">
          <div>
            <label style="display:block; font-size:11px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px;">
              ამოცანის ID
            </label>
            <input type="text" name="taskNames[]" required placeholder="task_a"
                   style="width:100%; padding:9px 12px; background:var(--bg-card); border:1px solid var(--border-mid); border-radius:var(--radius-md); color:var(--text-primary); font-family:var(--font-mono); font-size:13px; outline:none;">
          </div>
          <div>
            <label style="display:block; font-size:11px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px;">
              Time Limit (s)
            </label>
            <input type="number" step="0.1" name="taskTimeLimits" value="2.0" required
                   style="width:100%; padding:9px 12px; background:var(--bg-card); border:1px solid var(--border-mid); border-radius:var(--radius-md); color:var(--text-primary); font-family:var(--font-mono); font-size:13px; outline:none;">
          </div>
          <div>
            <label style="display:block; font-size:11px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px;">
              Memory (MiB)
            </label>
            <input type="number" name="taskMemoryLimits" value="256" required
                   style="width:100%; padding:9px 12px; background:var(--bg-card); border:1px solid var(--border-mid); border-radius:var(--radius-md); color:var(--text-primary); font-family:var(--font-mono); font-size:13px; outline:none;">
          </div>
        </div>

        <div style="margin-bottom: 10px;">
          <label style="display:block; font-size:11px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px;">
            PDF პირობა
          </label>
          <input type="file" name="taskPdfs" accept="application/pdf" required
                 style="width:100%; padding:8px 12px; background:var(--bg-card); border:1px solid var(--border-mid); border-radius:var(--radius-md); color:var(--text-secondary); font-size:12px;">
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
          <div>
            <label style="display:block; font-size:11px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px;">
              Input ფაილები
            </label>
            <input type="file" name="taskInputs" multiple required
                   style="width:100%; padding:8px 12px; background:var(--bg-card); border:1px solid var(--border-mid); border-radius:var(--radius-md); color:var(--text-secondary); font-size:12px;">
          </div>
          <div>
            <label style="display:block; font-size:11px; font-weight:700; letter-spacing:.5px; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px;">
              Output ფაილები
            </label>
            <input type="file" name="taskOutputs" multiple required
                   style="width:100%; padding:8px 12px; background:var(--bg-card); border:1px solid var(--border-mid); border-radius:var(--radius-md); color:var(--text-secondary); font-size:12px;">
          </div>
        </div>
      `;
      c.appendChild(div);
    }

    function removeTask(id) {
      document.getElementById('task_' + id).remove();
    }

    window.onload = () => addTask();
  </script>
</body>
</html>
