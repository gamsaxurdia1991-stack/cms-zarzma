<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <title>Create Contest</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f6f9; font-family: system-ui, sans-serif; }
        .task-block { background: #fff; border: 1px solid #dee2e6; border-radius: 6px; padding: 15px; margin-bottom: 15px; }
    </style>
</head>
<body>
    <div class="container my-5" style="max-width: 800px;">
        <div class="card shadow-sm p-4">
            <h3 class="fw-bold text-dark mb-4">➕ ახალი კონტესტის შექმნა</h3>
            
            <form action="/admin/create-contest" method="POST" enctype="multipart/form-data">
                
                <div class="mb-3">
                    <label class="form-label fw-bold">კონტესტის დასახელება</label>
                    <input type="text" name="title" class="form-control" required placeholder="მაგ: შიდა შესარჩევი ტური">
                </div>
                
                <div class="mb-4">
                    <label class="form-label fw-bold">ხანგრძლივობა (წუთებში)</label>
                    <input type="number" name="duration" class="form-control" value="180" required>
                </div>

                <hr>
                <h5 class="fw-bold text-secondary mb-3">🧩 ამოცანები (PDF პირობით & ფაილური ტესტებით)</h5>
                
                <div id="tasksContainer"></div>

                <button type="button" class="btn btn-outline-primary btn-sm fw-bold mb-4" onclick="addTaskBlock()">➕ ამოცანის დამატება</button>
                
                <hr>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success fw-bold px-4">კონტესტის შექმნა</button>
                    <a href="/contests" class="btn btn-light border fw-bold">უკან დაბრუნება</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        let taskCount = 0;

        function addTaskBlock() {
            taskCount++;
            const container = document.getElementById('tasksContainer');
            
            const taskHtml = `
                <div class="task-block shadow-sm" id="task_${taskCount}">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-primary m-0">ამოცანა #${taskCount}</h6>
                        <button type="button" class="btn btn-danger btn-sm p-1 px-2 small" onclick="removeTaskBlock(${taskCount})">წაშლა</button>
                    </div>
                    
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">ამოცანის ID (ინგლისურად, მაგ: task_a)</label>
                            <input type="text" name="taskNames[]" class="form-control form-control-sm" required placeholder="task_a">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Time Limit (წმ)</label>
                            <input type="number" step="0.1" name="taskTimeLimits[]" class="form-control form-control-sm" value="2.0" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold">Memory Limit (MB)</label>
                            <input type="number" name="taskMemoryLimits[]" class="form-control form-control-sm" value="256" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-danger">📄 ატვირთე ამოცანის პირობა (მხოლოდ PDF)</label>
                        <input type="file" name="taskPdfs" class="form-control form-control-sm" accept="application/pdf" required>
                    </div>

                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-success">📥 სატესტო შეყვანა (Input ფაილები)</label>
                            <input type="file" name="taskInputs" class="form-control form-control-sm" multiple required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-success">📤 სატესტო გამოყვანა (Output ფაილები)</label>
                            <input type="file" name="taskOutputs" class="form-control form-control-sm" multiple required>
                        </div>
                    </div>
                </div>
            `;
            
            container.insertAdjacentHTML('beforeend', taskHtml);
        }

        function removeTaskBlock(id) {
            document.getElementById(`task_${id}`).remove();
        }

        window.onload = function() {
            addTaskBlock();
        };
    </script>
</body>
</html>