<!DOCTYPE html>
<html lang="ka">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ადმინები — Zarzma Judge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>

  <nav class="zj-navbar">
    <a href="/contests" class="zj-logo">
      <span class="zj-logo-dot"></span>
      Zarzma Judge
    </a>
    <a href="/contests" class="btn-zj btn-zj-ghost btn-zj-sm">← Dashboard</a>
  </nav>

  <div style="max-width: 900px; margin: 0 auto; padding: 32px 24px;">

    <div class="flex-between mb-4">
      <div>
        <h2 style="font-size: 20px; margin-bottom: 4px;">Admin Management</h2>
        <p style="color: var(--text-muted); font-size: 13px;">ადმინისტრატორების სია და მართვა</p>
      </div>
    </div>

    <% if (currentRole === 'owner') { %>
    <div style="display: grid; grid-template-columns: 300px 1fr; gap: 20px; align-items: start;">

      <!-- Add admin form -->
      <div class="card-zj">
        <div class="card-header-zj">
          <span class="section-label" style="margin: 0;">ახალი ადმინის დამატება</span>
        </div>
        <form action="/register-admin" method="POST" class="form-zj">
          <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" required placeholder="nodar_admin">
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" required placeholder="admin@zarzma1.ge">
          </div>
          <div class="form-group" style="margin-bottom: 16px;">
            <label>პაროლი</label>
            <input type="password" name="password" required placeholder="••••••••">
          </div>
          <button type="submit" class="btn-zj btn-zj-primary w-100" style="justify-content: center;">
            + ადმინის დამატება
          </button>
        </form>
      </div>

      <!-- Admin list -->
      <div>
        <p class="section-label mb-2">რეგისტრირებული ადმინისტრატორები</p>
        <div class="card-zj" style="padding: 0; overflow: hidden;">
          <% if (!admins || admins.length === 0) { %>
            <div style="text-align: center; padding: 48px; color: var(--text-muted); font-size: 14px;">
              ადმინისტრატორები არ მოიძებნა.
            </div>
          <% } else { %>
            <table class="table-zj">
              <thead>
                <tr>
                  <th>Username</th>
                  <th>Email</th>
                  <th>სტატუსი</th>
                  <th class="center">მოქმედება</th>
                </tr>
              </thead>
              <tbody>
                <% admins.forEach(function(admin) { %>
                <tr>
                  <td style="font-weight: 700;"><%= admin.username %></td>
                  <td style="font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary);"><%= admin.email %></td>
                  <td>
                    <% if (admin.isOnline) { %>
                      <span class="badge-zj badge-ac">● აქტიურია</span>
                    <% } else { %>
                      <span class="badge-zj badge-muted">● Offline</span>
                    <% } %>
                  </td>
                  <td class="center">
                    <form action="/admin/delete-admin" method="POST" style="margin:0;"
                          onsubmit="return confirm('ნამდვილად გსურთ ამ ადმინის წაშლა?');">
                      <input type="hidden" name="adminId" value="<%= admin.id %>">
                      <button type="submit" class="btn-zj btn-zj-danger btn-zj-sm">წაშლა</button>
                    </form>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

    </div>
    <% } else { %>

    <!-- Admin view (no form, full width) -->
    <p class="section-label mb-2">რეგისტრირებული ადმინისტრატორები</p>
    <div class="card-zj" style="padding: 0; overflow: hidden;">
      <% if (!admins || admins.length === 0) { %>
        <div style="text-align: center; padding: 48px; color: var(--text-muted); font-size: 14px;">
          ადმინისტრატორები არ მოიძებნა.
        </div>
      <% } else { %>
        <table class="table-zj">
          <thead>
            <tr>
              <th>Username</th>
              <th>Email</th>
              <th>სტატუსი</th>
            </tr>
          </thead>
          <tbody>
            <% admins.forEach(function(admin) { %>
            <tr>
              <td style="font-weight: 700;"><%= admin.username %></td>
              <td style="font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary);"><%= admin.email %></td>
              <td>
                <% if (admin.isOnline) { %>
                  <span class="badge-zj badge-ac">● აქტიურია</span>
                <% } else { %>
                  <span class="badge-zj badge-muted">● Offline</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <% } %>
  </div>
</body>
</html>
