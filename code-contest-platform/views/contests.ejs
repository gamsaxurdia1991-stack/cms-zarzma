<!DOCTYPE html>
<html lang="ka">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contests — Zarzma Judge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>

  <!-- ── Navbar ── -->
  <nav class="zj-navbar">
    <a href="/contests" class="zj-logo">
      <span class="zj-logo-dot"></span>
      Zarzma Judge
    </a>
    <div class="zj-nav-right">
      <span style="font-size:12px; color:var(--text-muted);">
        <%= locals.username || (locals.email ? email.split('@')[0] : 'User') %>
      </span>
      <span class="badge-zj badge-muted mono"><%= role %></span>
      <a href="/logout" class="btn-zj btn-zj-ghost btn-zj-sm">გამოსვლა</a>
    </div>
  </nav>

  <!-- ── Main ── -->
  <div style="max-width: 820px; margin: 0 auto; padding: 32px 24px;">

    <!-- Admin controls -->
    <% if (role === 'admin' || role === 'owner') { %>
    <div class="admin-strip mb-4">
      <p class="section-label mb-2">Admin Controls</p>
      <div class="flex flex-center gap-2" style="flex-wrap: wrap;">
        <a href="/admin/create-contest"      class="btn-zj btn-zj-primary btn-zj-sm">+ კონტესტის შექმნა</a>
        <a href="/admin/register-student"    class="btn-zj btn-zj-ghost   btn-zj-sm">მოსწავლეები</a>
        <a href="/admin/scoreboard"          class="btn-zj btn-zj-ghost   btn-zj-sm">სქორბორდი</a>
        <a href="/communication"             class="btn-zj btn-zj-ghost   btn-zj-sm">კითხვები</a>
        <a href="/register-admin"            class="btn-zj btn-zj-ghost   btn-zj-sm">
          <%= role === 'owner' ? 'ადმინები' : 'ადმინები' %>
        </a>
      </div>
    </div>
    <% } %>

    <!-- Heading -->
    <div class="flex-between mb-3">
      <h2 style="font-size: 20px;">აქტიური კონტესტები</h2>
      <span class="badge-zj badge-muted mono">
        <%= (contests && contests.length) || 0 %> კონტესტი
      </span>
    </div>

    <!-- Contest list -->
    <% if (!contests || contests.length === 0) { %>
      <div class="card-zj" style="text-align: center; padding: 48px 24px;">
        <p style="color: var(--text-muted); font-size: 14px;">ჯერ არცერთი კონტესტი არ არის აქტიური.</p>
      </div>
    <% } else { %>
      <% contests.forEach(contest => { %>
      <div class="contest-row">
        <div>
          <div style="font-size: 16px; font-weight: 700; margin-bottom: 4px;"><%= contest.title %></div>
          <div class="flex flex-center gap-2 mt-1">
            <span class="badge-zj badge-muted mono">⏱ <%= contest.duration %> წთ</span>
            <% contest.tasks.forEach(t => { %>
              <span class="badge-zj badge-info mono"><%= t %></span>
            <% }) %>
          </div>
        </div>

        <div class="flex flex-center gap-2">
          <a href="/contest/<%= contest.id %>" class="btn-zj btn-zj-primary btn-zj-sm">შესვლა</a>

          <% if (role === 'admin' || role === 'owner') { %>
            <a href="/admin/configure-contest/<%= contest.id %>" class="btn-zj btn-zj-warning btn-zj-sm">კონფიგ.</a>
            <form action="/admin/delete-contest" method="POST" style="margin:0;"
                  onsubmit="return confirm('ნამდვილად გსურთ წაშლა?');">
              <input type="hidden" name="contestId" value="<%= contest.id %>">
              <button type="submit" class="btn-zj btn-zj-danger btn-zj-sm">წაშლა</button>
            </form>
          <% } %>
        </div>
      </div>
      <% }) %>
    <% } %>

  </div>
</body>
</html>
