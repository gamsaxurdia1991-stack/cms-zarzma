<!DOCTYPE html>
<html lang="ka">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>მოსწავლეები — Zarzma Judge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/style.css">
</head>
<body>

  <nav class="zj-navbar">
    <a href="/contests" class="zj-logo">
      <span class="zj-logo-dot"></span>
      Zarzma Judge
    </a>
    <a href="/contests" class="btn-zj btn-zj-ghost btn-zj-sm">← Dashboard</a>
  </nav>

  <div style="max-width: 820px; margin: 0 auto; padding: 32px 24px;">

    <div class="flex-between mb-4">
      <div>
        <h2 style="font-size: 20px; margin-bottom: 4px;">მოსწავლეების მართვა</h2>
        <p style="color: var(--text-muted); font-size: 13px;">მოსწავლეების დამატება და წაშლა სისტემიდან</p>
      </div>
      <span class="badge-zj badge-muted mono">
        <%= students ? students.length : 0 %> მოსწავლე
      </span>
    </div>

    <% if (success) { %>
      <div class="alert-zj alert-zj-success mb-4" style="font-size: 13px;"><%= success %></div>
    <% } %>

    <!-- Add student form -->
    <div class="card-zj mb-4">
      <div class="card-header-zj">
        <span class="section-label" style="margin: 0;">ახალი მოსწავლის დამატება</span>
      </div>
      <form action="/admin/register-student" method="POST" class="form-zj">
        <div style="display: grid; grid-template-columns: 2fr 2fr 1.5fr auto; gap: 10px; align-items: end;">
          <div class="form-group" style="margin: 0;">
            <label>სახელი და გვარი</label>
            <input type="text" name="username" required placeholder="გიორგი მაისურაძე" autocomplete="off">
          </div>
          <div class="form-group" style="margin: 0;">
            <label>Email</label>
            <input type="email" name="email" required placeholder="student@school.ge" autocomplete="off">
          </div>
          <div class="form-group" style="margin: 0;">
            <label>პაროლი</label>
            <input type="text" name="password" required placeholder="password123" autocomplete="off">
          </div>
          <button type="submit" class="btn-zj btn-zj-primary" style="height: 38px; white-space: nowrap;">+ დამატება</button>
        </div>
      </form>
    </div>

    <!-- Student list -->
    <p class="section-label mb-2">დარეგისტრირებული მოსწავლეები</p>
    <div class="card-zj" style="padding: 0; overflow: hidden;">
      <% if (students && students.length > 0) { %>
        <table class="table-zj">
          <thead>
            <tr>
              <th>სახელი და გვარი</th>
              <th>Email</th>
              <th>პაროლი</th>
              <th class="center">წაშლა</th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach(function(s) { %>
            <tr>
              <td style="font-weight: 600;"><%= s.username || '—' %></td>
              <td style="font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary);"><%= s.email %></td>
              <td>
                <code style="background: var(--bg-input); padding: 2px 8px; border-radius: 4px;
                     font-size: 12px; color: var(--text-secondary); font-family: var(--font-mono);">
                  <%= s.password %>
                </code>
              </td>
              <td class="center">
                <form action="/admin/unregister-student" method="POST" style="margin:0;"
                      onsubmit="return confirm('ნამდვილად გსურთ მოსწავლის წაშლა?');">
                  <input type="hidden" name="id" value="<%= s.id %>">
                  <button type="submit" class="btn-zj btn-zj-danger btn-zj-sm">წაშლა</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div style="text-align: center; padding: 48px 24px; color: var(--text-muted); font-size: 14px;">
          დარეგისტრირებული მოსწავლეები არ მოიძებნა.
        </div>
      <% } %>
    </div>

  </div>
</body>
</html>
