<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <title>Register Student - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light" style="padding-top: 50px; font-family: system-ui, sans-serif;">
    <div class="container" style="max-width: 850px;"> <div class="card card-body shadow-sm border-0 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h4 class="fw-bold m-0 text-dark">Register / Unregister Students</h4>
                <a href="/contests" class="btn btn-outline-secondary btn-sm fw-bold">Back</a>
            </div>

            <% if (success) { %>
                <div class="alert alert-info alert-dismissible fade show small py-2 fw-bold" role="alert">
                    <%= success %>
                </div>
            <% } %>

            <form action="/admin/register-student" method="POST" class="row g-2 mb-4">
                <div class="col-md-4">
                    <input type="text" name="username" class="form-control form-control-sm" placeholder="მოსწავლის სახელი და გვარი" required autocomplete="off">
                </div>
                <div class="col-md-3">
                    <input type="email" name="email" class="form-control form-control-sm" placeholder="Student Email" required autocomplete="off">
                </div>
                <div class="col-md-3">
                    <input type="text" name="password" class="form-control form-control-sm" placeholder="Password" required autocomplete="off">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary btn-sm w-100 fw-bold">Add Student</button>
                </div>
            </form>

            <h5 class="text-secondary small fw-bold mb-3">CURRENT REGISTERED STUDENTS</h5>
            <div class="list-group">
                <% if (students && students.length > 0) { %>
                    <% students.forEach(s => { %>
                        <div class="list-group-item d-flex justify-content-between align-items-center small py-2">
                            <div>
                                <span class="fw-bold text-dark me-2">👤 <%= s.username || 'სახელი არ აქვს' %></span>
                                <span class="text-muted small">📧 <%= s.email %></span>
                                <span class="text-muted ms-3">Password: <code><%= s.password %></code></span>
                            </div>
                            
                            <form action="/admin/unregister-student" method="POST" class="m-0" onsubmit="return confirm('ნამდვილად გსურთ მოსწავლის წაშლა?');">
                                <input type="hidden" name="id" value="<%= s.id %>">
                                <button type="submit" class="btn btn-danger btn-sm py-0 px-2 fw-bold" style="font-size: 11px;">Unregister</button>
                            </form>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-muted text-center small py-3">დარეგისტრირებული სტუდენტები არ მოიძებნა.</div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>