<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= (contest && contest.title) ? contest.title : 'Contest' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body { font-family: system-ui, sans-serif; display: flex; height: 100vh; overflow: hidden; margin:0; background-color: #f8f9fa; }
        
        /* Sidebar Styling */
        .sidebar { width: 260px; background-color: #ffffff; border-right: 1px solid #dee2e6; display: flex; flex-direction: column; justify-content: space-between; padding: 15px 0; z-index: 100; }
        .sidebar-menu a { display: block; padding: 10px 20px; color: #495057; text-decoration: none; font-size: 14px; transition: 0.2s; }
        .sidebar-menu a:hover { background-color: #f1f3f5; color: #0d6efd; }
        .sidebar-menu a.active { background-color: #e7f1ff; color: #0d6efd; font-weight: 600; border-right: 3px solid #0d6efd; }
        
        /* Content Area Styling */
        .content-area { flex: 1; padding: 40px; overflow-y: auto; background-color: #ffffff; }
        
        /* Components */
        .task-header { font-size: 11px; font-weight: 800; color: #adb5bd; padding: 15px 20px 5px 20px; text-transform: uppercase; letter-spacing: 0.5px; }
        .timer-badge { font-size: 18px; font-weight: 700; background: #212529; color: #ffc107; padding: 10px; border-radius: 6px; text-align: center; margin: 0 15px 20px 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); font-family: monospace; }
        
        /* CMS Styled Details Table */
        .cms-table { max-width: 800px; width: 100%; border-collapse: collapse; margin-top: 10px; margin-bottom: 30px; font-size: 15px; }
        .cms-table td { padding: 8px 12px; border: 1px solid #dee2e6; }
        .cms-table td:first-child { font-weight: bold; width: 200px; background-color: #fcfcfc; }
        
        /* Markdown / Text Formatting */
        .statement-box img { max-width: 100%; height: auto; border-radius: 4px; }
        .statement-box pre { background: #f8f9fa; padding: 15px; border-radius: 6px; border: 1px solid #e9ecef; font-family: 'Courier New', Courier, monospace; }
        .limit-badge { font-size: 12px; padding: 4px 10px; background: #f1f3f5; color: #495057; border-radius: 4px; border: 1px solid #dee2e6; font-weight: 600; }
        
        /* CMS Status Text Colors */
        .status-text { font-weight: bold; }
        .status-ac { color: #2ca02c; } /* მწვანე */
        .status-err { color: #cd3d4d; } /* CMS წითელი */
        
        /* CMS Details Link (როგორც ფოტოზეა) */
        .cms-details-link { font-size: 13px; color: #0088cc; text-decoration: none; margin-left: 6px; font-weight: normal; }
        .cms-details-link:hover { text-decoration: underline; }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-menu w-100">
            <div class="px-3 mb-3">
                <h5 class="fw-bold text-dark text-truncate m-0" title="<%= contest.title %>"><%= contest.title %></h5>
            </div>
            
            <div class="timer-badge" id="timer">00:00:00</div>

            <a href="/contest/<%= contest.id %>" class="<%= !currentTask && viewType !== 'all-submissions' ? 'active' : '' %>">
                🏠 Overview
            </a>
            <a href="/contest/<%= contest.id %>?view=all-submissions" class="<%= viewType === 'all-submissions' ? 'active' : '' %>">
                📝 My Submissions
            </a>
            <a href="/communication?contestId=<%= contest.id %>">
                💬 Communication
            </a>
            
            <hr class="mx-3 my-3">
            
            <% contest.tasks.forEach(task => { %>
                <div class="task-header"><%= task %></div>
                <a href="/contest/<%= contest.id %>?task=<%= encodeURIComponent(task) %>&view=statement" class="ps-4 <%= currentTask === task && viewType === 'statement' ? 'active' : '' %>">
                    📄 Statement
                </a>
                <a href="/contest/<%= contest.id %>?task=<%= encodeURIComponent(task) %>&view=submissions" class="ps-4 <%= currentTask === task && viewType === 'submissions' ? 'active' : '' %>">
                    📊 Submissions
                </a>
            <% }) %>
        </div>
        
        <div class="px-3 w-100">
            <hr>
            <a href="/contests" class="btn btn-outline-secondary btn-sm w-100 fw-bold py-2">⬅️ Back to List</a>
        </div>
    </div>

    <div class="content-area">
        
        <% if (viewType === 'all-submissions') { %>
            <h3 class="fw-bold mb-4">ჩემი ყველა გაგზავნილი კოდი</h3>
            <div class="table-responsive">
                <table class="table table-hover align-middle border shadow-sm" style="background: white;">
                    <thead class="table-dark">
                        <tr><th>გაგზავნის დრო</th><th>ამოცანა</th><th>სტატუსი</th><th>ქულა</th></tr>
                    </thead>
                    <tbody>
                        <% if (typeof submissions !== 'undefined' && submissions.length > 0) { %>
                            <% submissions.reverse().forEach(s => { %>
                                <tr>
                                    <td class="text-muted small fw-bold">
                                        <a href="/submission/<%= s.id %>" class="text-decoration-none text-muted"><%= s.time %></a>
                                    </td>
                                    <td class="fw-bold"><%= s.taskName %></td>
                                    <td>
                                        <% 
                                            let statusClass = s.status.includes('Accepted') ? 'status-ac' : 'status-err';
                                        %>
                                        <span class="status-text <%= statusClass %>"><%= s.status %></span>
                                        <a href="/submission/<%= s.id %>" class="cms-details-link">(details)</a>
                                    </td>
                                    <td class="fw-bold fs-5">
                                        <a href="/submission/<%= s.id %>" class="text-decoration-none text-dark"><%= s.points %></a>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="4" class="text-center py-4 text-muted">ჯერ არცერთი კოდი არ გაგიგზავნიათ.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

        <% } else if (currentTask) { %>
            
            <div class="mb-4">
                <ul class="nav nav-tabs">
                    <li class="nav-item">
                        <a class="nav-link <%= viewType === 'statement' ? 'active fw-bold text-dark' : 'text-secondary' %>" href="/contest/<%= contest.id %>?task=<%= encodeURIComponent(currentTask) %>&view=statement">Statement</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= viewType === 'submissions' ? 'active fw-bold text-dark' : 'text-secondary' %>" href="/contest/<%= contest.id %>?task=<%= encodeURIComponent(currentTask) %>&view=submissions">Submissions</a>
                    </li>
                </ul>
            </div>

            <% if (viewType === 'statement') { %>
                <div class="mb-3">
                    <h1 class="fw-bold d-inline-block m-0" style="font-size: 38px;"><%= currentTask %></h1>
                    <span class="text-muted ms-2 fs-5">description</span>
                </div>
                
                <h3 class="fw-normal text-secondary mt-4 mb-3">Statement</h3>
                
                <% if (typeof pdfUrl !== 'undefined' && pdfUrl) { %>
                    <div class="mb-4">
                        <a href="<%= pdfUrl %>" download class="btn btn-success fw-semibold px-4 py-2" style="background-color: #5cb85c; border-color: #4cae4c;">
                            Download task statement
                        </a>
                    </div>
                <% } %>

                <div class="statement-box mb-5">
                    <%- taskStatementHtml %>
                </div>

                <h3 class="fw-normal text-secondary mt-5 mb-3">Some details</h3>
                <table class="cms-table">
                    <tbody>
                        <tr>
                            <td>Type</td>
                            <td>Batch</td>
                        </tr>
                        <tr>
                            <td>Time limit</td>
                            <td><%= (typeof taskLimits !== 'undefined' && taskLimits.timeLimit) ? Number(taskLimits.timeLimit).toFixed(3) : "2.000" %> seconds</td>
                        </tr>
                        <tr>
                            <td>Memory limit</td>
                            <td><%= (typeof taskLimits !== 'undefined' && taskLimits.memoryLimit) ? taskLimits.memoryLimit : "256" %> MiB</td>
                        </tr>
                        <tr>
                            <td>Remaining Submissions</td>
                            <td><%= typeof remainingSubmissions !== 'undefined' ? remainingSubmissions : 50 %> / 50</td>
                        </tr>
                    </tbody>
                </table>

            <% } else if (viewType === 'submissions') { %>
                <div class="card border-primary shadow-sm mb-4" id="submit-card">
                    <div class="card-header bg-primary text-white fw-bold py-2">SUBMIT SOLUTION (C++)</div>
                    <div class="card-body p-3">
                        <% if (typeof remainingSubmissions !== 'undefined' && remainingSubmissions <= 0) { %>
                            <div class="alert alert-danger m-0">თქვენ ამოგეწურათ ამ ამოცანაზე კოდის გაგზავნის ლიმიტი (მაქსიმუმ 50).</div>
                        <% } else { %>
                            <form action="/submit-code" method="POST" enctype="multipart/form-data" class="row g-2">
                                <input type="hidden" name="contestId" value="<%= contest.id %>">
                                <input type="hidden" name="taskName" value="<%= currentTask %>">
                                <div class="col-md-9">
                                    <input type="file" name="codeFile" class="form-control" accept=".cpp" required id="fileInput">
                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-success w-100 fw-bold" id="submitBtn">🚀 Submit Code</button>
                                </div>
                            </form>
                        <% } %>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle border shadow-sm" style="background: white;">
                        <thead class="table-light">
                            <tr>
                                <th>გაგზავნის დრო</th>
                                <th>სტატუსი</th>
                                <th>ქულა</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof submissions !== 'undefined' && submissions.length > 0) { %>
                                <% submissions.reverse().forEach(s => { %>
                                    <% if (s.taskName === currentTask) { %>
                                        <tr>
                                            <td class="text-muted small fw-bold" style="width: 30%;">
                                                <a href="/submission/<%= s.id %>" class="text-decoration-none text-muted"><%= s.time %></a>
                                            </td>
                                            <td style="width: 50%;">
                                                <% 
                                                    let statusClass = s.status.includes('Accepted') ? 'status-ac' : 'status-err';
                                                %>
                                                <span class="status-text <%= statusClass %>"><%= s.status %></span>
                                                <a href="/submission/<%= s.id %>" class="cms-details-link">(details)</a>
                                            </td>
                                            <td class="fw-bold" style="width: 20%;">
                                                <a href="/submission/<%= s.id %>" class="text-decoration-none text-dark"><%= s.points %></a>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="3" class="text-center py-3 text-muted">ამ ამოცანაზე ისტორია ცარიელია.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            <% } %>

        <% } else { %>
            <div class="overview-section">
                <div class="mb-5">
                    <h2 class="fw-bold text-dark mb-2">Contest Overview</h2>
                    <p class="text-muted">კეთილი იყოს თქვენი მობრძანება <b><%= contest.title %></b>-ზე. ქვემოთ მოცემულია ამოცანების სია და ლიმიტები.</p>
                </div>
                
                <h5 class="fw-bold text-secondary small mb-3 text-uppercase">ამოცანების ჩამონათვალი</h5>
                <div class="table-responsive">
                    <table class="table table-hover align-middle border shadow-sm" style="background: white;">
                        <thead class="table-light">
                            <tr class="small fw-bold text-muted">
                                <th class="ps-3" style="width: 50px;">#</th>
                                <th>სახელი</th>
                                <th>დროის ლიმიტი</th>
                                <th>მეხსიერების ლიმიტი</th>
                                <th class="text-center">გაგზავნა</th>
                                <th class="text-center" style="width: 150px;">მოქმედება</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% contest.tasks.forEach((task, index) => { 
                                let tData = (contest.tasksData && contest.tasksData.find(t => String(t.name).trim() === String(task).trim())) || null;
                                let timeLimit = tData ? Number(tData.timeLimit).toFixed(3) + 's' : '2.000s';
                                let memoryLimit = tData ? tData.memoryLimit + ' MiB' : '256 MiB';
                            %>
                                <tr>
                                    <td class="ps-3 text-muted fw-bold"><%= index + 1 %></td>
                                    <td class="fw-bold text-dark fs-5"><%= task %></td>
                                    <td><span class="badge bg-light text-dark border"><%= timeLimit %></span></td>
                                    <td><span class="badge bg-light text-dark border"><%= memoryLimit %></span></td>
                                    <td class="text-center text-muted">მაქს. 50</td>
                                    <td class="text-center">
                                        <a href="/contest/<%= contest.id %>?task=<%= encodeURIComponent(task) %>&view=statement" class="btn btn-sm btn-primary fw-bold px-3">გახსნა</a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div class="alert alert-info mt-5 border-0 shadow-sm">
                    <h6 class="fw-bold">💡 წესები და მითითებები:</h6>
                    <ul class="m-0 small">
                        <li>თითოეულ ამოცანაზე გაქვთ მაქსიმუმ 50 მცდელობა.</li>
                        <li>კოდი უნდა იყოს დაწერილი C++ ენაზე.</li>
                        <li>დროის ამოწურვის შემდეგ სისტემა ავტომატურად დაიბლოკება სტანდარტული იუზერებისთვის.</li>
                        <li>კითხვების შემთხვევაში გამოიყენეთ Communication სექცია.</li>
                    </ul>
                </div>
            </div>
        <% } %>
    </div>

    <script>
        let timeLeft = Number("<%= typeof timeLeft !== 'undefined' ? timeLeft : 0 %>");
        if (isNaN(timeLeft)) timeLeft = 0;

        const timerDisplay = document.getElementById('timer');
        const submitBtn = document.getElementById('submitBtn');
        const fileInput = document.getElementById('fileInput');

        function updateTimer() {
            if (timeLeft <= 0) {
                if(timerDisplay) {
                    timerDisplay.innerHTML = "FINISHED (UPSOLVING OPEN)";
                    timerDisplay.style.color = "#ffc107";
                }
                
                const userRole = "<%= typeof role !== 'undefined' ? role : 'user' %>";
                if (userRole !== 'admin' && userRole !== 'checker' && userRole !== 'owner') {
                    if(submitBtn) { 
                        submitBtn.disabled = true; 
                        submitBtn.classList.replace('btn-success', 'btn-secondary');
                        submitBtn.innerText = "Blocked (Contest Ended)"; 
                    }
                    if(fileInput) fileInput.disabled = true;
                }
                return;
            }
            
            let hours = Math.floor(timeLeft / 3600000);
            let minutes = Math.floor((timeLeft % 3600000) / 60000);
            let seconds = Math.floor((timeLeft % 60000) / 1000);
            
            if(timerDisplay) {
                timerDisplay.innerHTML = 
                    (hours < 10 ? "0" : "") + hours + ":" + 
                    (minutes < 10 ? "0" : "") + minutes + ":" + 
                    (seconds < 10 ? "0" : "") + seconds;
            }
            
            timeLeft -= 1000;
        }
        
        setInterval(updateTimer, 1000);
        updateTimer();
    </script>
</body>
</html>