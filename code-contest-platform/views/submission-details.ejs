<!DOCTYPE html>
<html lang="ka">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submission — Zarzma Judge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/style.css">
  <style>
    .score-display { font-family: var(--font-mono); font-size: 32px; font-weight: 800; }
    .score-label   { font-weight: 700; font-size: 15px; margin-bottom: 4px; }
    .col-green  { color: var(--green); }
    .col-yellow { color: var(--yellow); }
    .col-red    { color: var(--red); }
  </style>
</head>
<body>

  <nav class="zj-navbar">
    <a href="/contests" class="zj-logo">
      <span class="zj-logo-dot"></span>
      Zarzma Judge
    </a>
    <a href="/contest/<%= sub.contestId %>?task=<%= encodeURIComponent(sub.taskName) %>&view=submissions"
       class="btn-zj btn-zj-ghost btn-zj-sm">← უკან</a>
  </nav>

  <div style="max-width: 860px; margin: 0 auto; padding: 32px 24px;">

    <%
      var pts        = parseInt(sub.points) || 0;
      var isAc       = pts === 100;
      var isPartial  = pts > 0 && pts < 100;
      var colorClass = isAc ? 'col-green' : (isPartial ? 'col-yellow' : 'col-red');
      var badgeClass = isAc ? 'badge-ac'  : (isPartial ? 'badge-warn'  : 'badge-err');
      var scoreLabel = isAc ? '✓ Accepted' : (isPartial ? '~ Partial Credit' : '✗ Not Accepted');
    %>

    <!-- Header -->
    <div class="flex-between mb-4">
      <div>
        <p class="section-label mb-1">Submission</p>
        <h2 style="font-size: 18px; font-family: var(--font-mono);">#<%= sub.id %></h2>
      </div>
      <div class="flex flex-center gap-2">
        <span class="badge-zj badge-info mono"><%= sub.taskName %></span>
        <span class="badge-zj <%= badgeClass %> mono"><%= pts %> / 100</span>
      </div>
    </div>

    <!-- Score card -->
    <div class="card-zj mb-4" style="padding: 20px 24px;">
      <div class="flex-between">
        <div>
          <div class="score-label <%= colorClass %>"><%= scoreLabel %></div>
          <div style="font-size: 12px; color: var(--text-muted);">Main Test Suite — <%= sub.taskName %></div>
        </div>
        <div class="score-display <%= colorClass %>">
          <%= pts %><span style="font-size: 14px; color: var(--text-muted); font-weight: 400;">/100</span>
        </div>
      </div>
    </div>

    <!-- Compilation output -->
    <p class="section-label mb-2">Compilation output</p>
    <div class="card-zj mb-4" style="padding: 0; overflow: hidden;">
      <table class="details-table" style="max-width: 100%; width: 100%;">
        <tr>
          <td>Compilation outcome</td>
          <td>
            <% if (sub.status && sub.status.includes('Compilation failed')) { %>
              <span class="col-red" style="font-weight: 700; font-family: var(--font-mono); font-size: 13px;">Compilation failed</span>
            <% } else { %>
              <span class="col-green" style="font-weight: 700; font-family: var(--font-mono); font-size: 13px;">Compilation succeeded</span>
            <% } %>
          </td>
        </tr>
        <tr>
          <td>Compilation time</td>
          <td style="font-family: var(--font-mono); font-size: 13px; color: var(--text-primary);"><%= sub.compilationTime || '—' %></td>
        </tr>
        <tr>
          <td>Memory used</td>
          <td style="font-family: var(--font-mono); font-size: 13px; color: var(--text-primary);"><%= sub.memoryUsed || '147 MiB' %></td>
        </tr>
        <tr>
          <td>Execution max time</td>
          <td style="font-family: var(--font-mono); font-size: 13px; color: var(--text-primary);"><%= sub.executionTime || '0.000 sec' %></td>
        </tr>
      </table>
    </div>

    <!-- Stdout -->
    <p class="section-label mb-2">Standard output</p>
    <div style="background: var(--bg-input); border: 1px solid var(--border); border-radius: var(--radius-md);
         padding: 12px 14px; font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary);
         min-height: 40px; margin-bottom: 16px; word-break: break-all;">
      <%= sub.stdout || '' %>
    </div>

    <!-- Stderr -->
    <p class="section-label mb-2">Standard error</p>
    <div style="background: var(--bg-input); border: 1px solid var(--border); border-radius: var(--radius-md);
         padding: 12px 14px; font-family: var(--font-mono); font-size: 12px; color: var(--text-secondary);
         min-height: 40px; margin-bottom: 24px; word-break: break-all;">
      <%= sub.stderr || '' %>
    </div>

    <!-- Meta + download -->
    <div class="flex-between mb-4">
      <div style="font-size: 12px; color: var(--text-muted);">
        ამოცანა: <span style="color: var(--text-primary); font-weight: 600;"><%= sub.taskName %></span>
        &nbsp;·&nbsp;
        მომხმარებელი: <span style="color: var(--text-primary);"><%= sub.email %></span>
      </div>
      <% if (sub.savedFilename) { %>
        <a href="/download-code/<%= sub.id %>" class="btn-zj btn-zj-success btn-zj-sm">↓ .cpp გადმოწერა</a>
      <% } %>
    </div>

    <!-- Source code -->
    <% if (sub.codeContent) { %>
      <p class="section-label mb-2">Source code</p>
      <div style="background: #0d0d10; border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px; overflow-x: auto;">
        <pre style="margin: 0; font-family: var(--font-mono); font-size: 13px; color: #e0e0e0;
             white-space: pre-wrap; word-wrap: break-word; line-height: 1.6;
             max-height: 520px; overflow-y: auto;"><%= sub.codeContent %></pre>
      </div>
    <% } %>

  </div>
</body>
</html>
