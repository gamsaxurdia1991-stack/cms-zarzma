<!DOCTYPE html>
<html lang="ka">
<head>
    <meta charset="UTF-8">
    <title>Admin Scoreboard - cms.zarzma1.ge</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fafafa; font-family: system-ui, sans-serif; }
        .main-box { background: white; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); padding: 30px; margin-top: 50px; }
    </style>
</head>
<body>
    <div class="container" style="max-width: 1000px;">
        <div class="main-box">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h4 class="text-dark fw-bold m-0">Admin Scoreboard</h4>
                <a href="/contests" class="btn btn-outline-secondary btn-sm fw-bold">Back to Contests</a>
            </div>

            <div class="card card-body bg-light mb-4 border-0 shadow-sm">
                <form action="/admin/scoreboard" method="GET" class="row g-2 align-items-center">
                    <div class="col-md-8">
                        <label class="form-label small fw-bold text-secondary mb-1">აირჩიე კონტესტი შედეგების სანახავად:</label>
                        <select name="contestId" class="form-select form-select-sm" onchange="this.form.submit()">
                            <option value="">-- აირჩიე კონტესტი სიიდან --</option>
                            <% contests.forEach(c => { %>
                                <option value="<%= c.id %>" <%= selectedContest && selectedContest.id === c.id ? 'selected' : '' %>>
                                    <%= c.title %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </form>
            </div>

            <% if (!selectedContest) { %>
                <div class="text-center my-5 text-muted">
                    <h5>გთხოვთ აირჩიოთ კონტესტი ზედა მენიუდან შედეგების სანახავად.</h5>
                </div>
            <% } else { %>
                <h5 class="text-primary fw-bold mb-3">კონტესტი: <%= selectedContest.title %></h5>
                
                <table class="table table-striped table-bordered bg-white small">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 8%;">Rank</th>
                            <th>User (Email)</th>
                            <% selectedContest.tasks.forEach(task => { %>
                                <th>Task: <%= task %></th>
                            <% }) %>
                            <th style="width: 15%;">Total Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (scoreboard.length === 0) { %>
                            <tr>
                                <td colspan="<%= 3 + selectedContest.tasks.length %>" class="text-center text-muted py-4">
                                    ამ კონტესტზე ჯერ არცერთი გამოგზავნილი კოდი (Submission) არ ფიქსირდება.
                                </td>
                            </tr>
                        <% } else { %>
                            <% scoreboard.forEach((sub, index) => { %>
                                <tr>
                                    <td class="fw-bold"><%= index + 1 %></td>
                                    <td><%= sub.email %> <br><small class="text-muted"><%= sub.time %> - [<%= sub.status %>]</small></td>
                                    
                                    <% selectedContest.tasks.forEach(task => { %>
                                        <td class="fw-bold <%= sub.taskName === task ? (sub.points === 100 ? 'text-success' : 'text-warning') : '' %>">
                                            <%= sub.taskName === task ? sub.points : '-' %>
                                        </td>
                                    <% }) %>
                                    
                                    <td class="fw-bold text-primary"><%= sub.points %></td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>
</body>
</html>